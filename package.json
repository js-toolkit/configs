{
  "name": "@js-toolkit/configs",
  "version": "3.109.2",
  "description": "Preconfigured configurations",
  "author": "VZH",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/js-toolkit/configs"
  },
  "type": "module",
  "exports": {
    "./js/*.json": "./js/*.json",
    "./ts/*.json": "./ts/*.json",
    "./prettier": {
      "types": "./types/prettier/index.d.ts",
      "import": "./esm/prettier/index.js",
      "require": "./cjs/prettier/index.js"
    },
    "./*/*": {
      "types": "./types/*/*.d.ts",
      "import": "./esm/*/*.js",
      "require": "./cjs/*/*.js"
    },
    "./*": {
      "types": "./types/*.d.ts",
      "require": "./cjs/*.js",
      "import": "./esm/*.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist/*",
    "copy:configs": "copyfiles package.json .npmignore README.md LICENSE ./dist/",
    "copy": "copyfiles --exclude './src/**/*.ts' --up 1 './src/**/*' ./dist/ && npm run copy:configs",
    "minify": "node ../node-utils/dist/bin/minify.js --replace ./dist",
    "build:cjs": "node scripts/build.cjs.ts",
    "build:esm": "tsc -p tsconfig.json",
    "build": "npm run clean && npm run build:esm && npm run build:cjs && node scripts/postbuild.ts",
    "lint": "eslint '**/*.{js,jsx,ts,tsx}' --flag unstable_native_nodejs_ts_config",
    "patch-publish": "yarn run build && yarn run minify && npm version patch --no-workspaces-update -m 'v%s' && yarn run copy && cd ./dist && npm publish --access public && git push --follow-tags",
    "minor-publish": "yarn run build && yarn run minify && npm version minor --no-workspaces-update -m 'v%s' && yarn run copy && cd ./dist && npm publish --access public && git push --follow-tags"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.3",
    "@eslint/js": "10.0.1",
    "@types/eslint": "9.6.1",
    "@types/node": "25.5.0",
    "@types/webpack-node-externals": "3.0.4",
    "@typescript-eslint/utils": "8.58.0",
    "copy-webpack-plugin": "14.0.0",
    "copyfiles": "2.4.1",
    "eslint": "9.39.4",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-standard": "17.1.0",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "globals": "17.4.0",
    "html-webpack-plugin": "5.6.6",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "ts-api-utils": "2.5.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0",
    "webpack": "5.105.4",
    "webpack-dev-server": "5.2.3",
    "webpack-node-externals": "3.0.0"
  }
}
