{
  "extends": "./src/ts/common.tsconfig.json",
  "compilerOptions": {
    "target": "es2015",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist/cjs",
    "moduleSuffixes": [".cjs", ""],
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "declaration": false,
    "sourceMap": false,
    "importHelpers": false
  },
  "include": ["src"],
  "exclude": ["src/defaultRequire.ts"]
}
