{
  "extends": "./src/ts/common.tsconfig.json",
  "compilerOptions": {
    "target": "es2015",
    "module": "commonjs",
    "moduleResolution": "bundler",
    "rootDir": "src",
    "outDir": "dist/cjs",
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "declaration": false,
    "sourceMap": false,
    "importHelpers": false
  },
  "include": ["src"]
}
