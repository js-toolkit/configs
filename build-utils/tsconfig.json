{
  "extends": "@js-toolkit/tsconfig/common",
  "compilerOptions": {
    "target": "es2015",
    "module": "es2020",
    "moduleResolution": "bundler",
    "types": ["webpack-dev-server", "node"],
    "rootDir": "src",
    "outDir": "dist/esm",
    "declarationDir": "dist/types",
    "declaration": true,
    "sourceMap": false,
    "importHelpers": false
  },
  "include": ["src"]
}
