{
  "extends": "@js-toolkit/tsconfig/common",
  "compilerOptions": {
    "target": "es2015",
    "module": "commonjs",
    "moduleResolution": "bundler",
    "types": ["webpack-dev-server", "node"],
    "rootDir": "src",
    "outDir": "dist/cjs",
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "declaration": false,
    "sourceMap": false,
    "importHelpers": false
  },
  "include": ["src"]
}
